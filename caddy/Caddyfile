# Caddy сам получает и продлевает TLS-сертификаты Let's Encrypt.
# Домены берутся из переменных окружения (см. корневой .env).
# Сервисы слушают порт 80 в своей сети — Caddy проксирует на них
# (включая websocket — отдельной настройки не нужно).
#
# ВАЖНО: обе переменные должны быть заданы, иначе пустой адрес сайта = ошибка.
# Не нужен какой-то сайт — удали его блок здесь.

{$VW_DOMAIN} {
	reverse_proxy vaultwarden:80
}

{$NTFY_DOMAIN} {
	reverse_proxy ntfy:80
}

{$KUMA_DOMAIN} {
	reverse_proxy uptime-kuma:3001
}

{$WALLOS_DOMAIN} {
	reverse_proxy wallos:80
}
