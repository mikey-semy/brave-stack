# Caddy сам получает и продлевает TLS-сертификат Let's Encrypt для домена.
# Домен берётся из переменной окружения VW_DOMAIN (см. корневой .env).
# Vaultwarden слушает порт 80 внутри своей сети — Caddy проксирует на него
# (включая websocket для мгновенных уведомлений — отдельной настройки не нужно).

{$VW_DOMAIN} {
	reverse_proxy vaultwarden:80
}
