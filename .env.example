# Общий конфиг сборки brave-stack. Скопируй в .env:  cp .env.example .env
# Используется и корневым compose, и per-app compose при запуске из корня.

# --- RustDesk ---
# Публичный IP или домен сервера (клиенты получат его как relay)
RELAY_HOST=89.23.101.7

# --- Vaultwarden + Caddy ---
# Поддомен для менеджера паролей (БЕЗ https://), A-запись → IP сервера
VW_DOMAIN=vault.example.ru
# Регистрация: true только на время создания своего аккаунта, потом false + передеплой
VW_SIGNUPS_ALLOWED=false
# Токен админ-панели /admin (необязательно). Сгенерировать: openssl rand -base64 48
VW_ADMIN_TOKEN=

# --- ntfy ---
# Поддомен для пуш-уведомлений (БЕЗ https://), A-запись → IP сервера
NTFY_DOMAIN=ntfy.example.ru

# --- Uptime Kuma ---
# Поддомен для мониторинга (БЕЗ https://), A-запись → IP сервера
KUMA_DOMAIN=status.example.ru
