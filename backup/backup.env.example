# Конфиг бэкапов. Скопируй в backup.env и заполни (backup.env в .gitignore):
#   cp backup/backup.env.example backup/backup.env

# --- ЧТО бэкапим: абсолютные пути к data-каталогам через пробел ---
# RustDesk хранит ключ+БД устройств в rustdesk/data. При добавлении сервисов дописывай пути.
BACKUP_PATHS="/root/brave-stack/rustdesk/data"
# пример с Vaultwarden: "/root/remote-app/data /opt/stacks/vaultwarden/vw-data"

# --- КУДА: rclone remote:бакет/путь ---
# remote с именем 'backup' создаётся скриптом setup-backup.sh из ключей ниже.
RCLONE_REMOTE="backup:ИМЯ_БАКЕТА/brave"

# --- Провайдер: b2 | s3 ---
PROVIDER="b2"

# Backblaze B2 (PROVIDER=b2):
B2_KEY_ID=""
B2_APP_KEY=""

# Любое S3-совместимое (PROVIDER=s3):
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""        # напр. https://s3.eu-central-003.backblazeb2.com
S3_REGION="auto"

# --- Сколько хранить копий на удалёнке (дни) ---
RETENTION_DAYS="14"

# --- Шифрование архива (опц.): GPG recipient/email. Пусто = без шифрования ---
# Рекомендуется: бэкап с паролями/ключами уезжает к стороннему провайдеру.
GPG_RECIPIENT=""

# --- Уведомления ntfy (опц.): URL топика, чтобы получать «готово/ошибка» ---
NTFY_URL=""
